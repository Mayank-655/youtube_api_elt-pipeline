# Copy this file to ".env" and fill in your values (never commit .env).
# Docker Compose reads .env in the SAME folder as docker-compose.yaml for ${VAR} substitution.
# Prefer unquoted values (especially passwords) so Postgres init and Airflow use the same string.

# Docker Hub image coordinates for the custom Airflow image
DOCKERHUB_NAMESPACE=your_dockerhub_username
DOCKERHUB_REPOSITORY=your_repo_name
IMAGE_TAG=1.0.0

# Postgres superuser (matches postgres service)
POSTGRES_CONN_USERNAME=postgres
POSTGRES_CONN_PASSWORD=change_me_strong_password
POSTGRES_CONN_HOST=postgres
POSTGRES_CONN_PORT=5432

# Metadata database (Airflow)
METADATA_DATABASE_NAME=airflow_metadata_db
METADATA_DATABASE_USERNAME=airflow_meta_user
METADATA_DATABASE_PASSWORD=change_me_metadata

# Celery result backend
CELERY_BACKEND_NAME=celery_results_db
CELERY_BACKEND_USERNAME=celery_user
CELERY_BACKEND_PASSWORD=change_me_celery

# ELT / warehouse database
ELT_DATABASE_NAME=elt_db
ELT_DATABASE_USERNAME=yt_api_user
ELT_DATABASE_PASSWORD=change_me_elt

# Airflow
AIRFLOW_UID=50000
AIRFLOW_WWW_USER_USERNAME=airflow
AIRFLOW_WWW_USER_PASSWORD=change_me_airflow_ui
FERNET_KEY=generate_a_fernet_key_for_airflow

# YouTube Data API
API_KEY=your_youtube_api_key
CHANNEL_HANDLE=YourChannelHandle

# ---------------------------------------------------------------------------
# Testing, SODA, and CI/CD alignment
# ---------------------------------------------------------------------------
# Airflow Variables are passed as AIRFLOW_VAR_* in docker-compose for workers.
# The warehouse Postgres connection is set via AIRFLOW_CONN_POSTGRES_DB_YT_ELT in compose.
#
# SODA (data_quality DAG) uses ELT_* and POSTGRES_CONN_* from the worker environment;
# values must match the elt_db role created by docker/postgres/init-multiple-databases.sh.
#
# For pytest against Postgres exposed on the host:
#   POSTGRES_CONN_HOST=localhost
#   POSTGRES_CONN_PORT=5432
# Integration tests skip when ELT_* / POSTGRES_* are incomplete.
#
# Pytest markers (see pytest.ini):
#   pytest tests/ -m unit
#   pytest tests/ -m "functional or unit"
#   pytest tests/ -m integration
#   pytest tests/ -m e2e

# ---------------------------------------------------------------------------
# GitHub Actions: variables and secrets
# ---------------------------------------------------------------------------
# Variables (Settings → Secrets and variables → Actions → Variables):
#   DOCKERHUB_NAMESPACE, DOCKERHUB_REPOSITORY, DOCKERHUB_USERNAME
#   CHANNEL_HANDLE, AIRFLOW_UID (e.g. 50000), optional IMAGE_TAG (defaults to latest in CI)
#
# Secrets (Settings → Secrets and variables → Actions → Secrets):
#   DOCKERHUB_PASSWORD
#   POSTGRES_CONN_USERNAME, POSTGRES_CONN_PASSWORD, POSTGRES_CONN_HOST, POSTGRES_CONN_PORT
#   METADATA_DATABASE_NAME, METADATA_DATABASE_USERNAME, METADATA_DATABASE_PASSWORD
#   CELERY_BACKEND_NAME, CELERY_BACKEND_USERNAME, CELERY_BACKEND_PASSWORD
#   ELT_DATABASE_NAME, ELT_DATABASE_USERNAME, ELT_DATABASE_PASSWORD
#   FERNET_KEY, AIRFLOW_WWW_USER_USERNAME, AIRFLOW_WWW_USER_PASSWORD
#   API_KEY
#
# Pushes to main or feature/* and PRs to main run .github/workflows/ci-cd.yaml.
# Manual run: Actions → "CI-CD Pipeline" → Run workflow (optional: skip DAG CLI tests).
#
# Fork PRs: repository secrets are not passed to workflows from forks unless you use
# pull_request_target (not recommended without a hardening review).
